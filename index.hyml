<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>إلى أغلى حد في حياتي ♥️</title>
    <style>
        * {
            box-sizing: border-box;
            margin: 0;
            padding: 0;
        }
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            background: linear-gradient(135deg, #f5f7fa 0%, #e4e8f0 100%);
            min-height: 100vh;
            display: flex;
            justify-content: center;
            align-items: center;
            overflow-x: hidden;
        }
        /* شاشة الباسورد */
        #password-screen {
            position: fixed;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: #f5f7fa;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            z-index: 1000;
            transition: all 0.5s ease;
        }
        #password-screen h2 {
            color: #4a5568;
            margin-bottom: 20px;
            font-size: 20px;
        }
        #password-screen input {
            padding: 12px;
            font-size: 16px;
            border: 2px solid #cbd5e1;
            border-radius: 8px;
            text-align: center;
            outline: none;
            margin-bottom: 15px;
            width: 200px;
        }
        #password-screen button {
            padding: 10px 25px;
            background-color: #ff7675;
            color: white;
            border: none;
            border-radius: 8px;
            cursor: pointer;
            font-size: 16px;
        }
        /* المحتوى الرئيسي */
        #main-content {
            display: none;
            width: 100%;
            max-width: 500px;
            padding: 20px;
            text-align: center;
            position: relative;
        }
        .card {
            background: rgba(255, 255, 255, 0.85);
            backdrop-filter: blur(10px);
            padding: 30px 20px;
            border-radius: 20px;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05);
            margin-bottom: 25px;
            border: 1px solid rgba(255,255,255,0.5);
        }
        .message-text {
            font-size: 18px;
            line-height: 1.8;
            color: #2d3748;
            white-space: pre-line;
            font-weight: 500;
        }
        /* معرض الصور */
        .gallery {
            display: flex;
            flex-direction: column;
            gap: 20px;
            margin-top: 20px;
        }
        .gallery img {
            width: 100%;
            border-radius: 15px;
            box-shadow: 0 5px 15px rgba(0,0,0,0.08);
            object-fit: cover;
        }
        /* تأثير القلوب */
        .heart {
            position: fixed;
            color: #ff7675;
            font-size: 14px;
            pointer-events: none;
            z-index: 999;
            animation: fall linear forwards;
        }
        @keyframes fall {
            0% {
                transform: translateY(-20px) rotate(0deg);
                opacity: 1;
            }
            100% {
                transform: translateY(105vh) rotate(360deg);
                opacity: 0;
            }
        }
        /* مشغل الصوت المخفي */
        audio {
            display: none;
        }
    </style>
</head>
<body>

    <div id="password-screen">
        <h2>ادخلي تاريخ اليوم المميز بتاعنا (D/M/YYYY) ♥️</h2>
        <input type="text" id="password-input" placeholder="13/7/2009">
        <button onclick="checkPassword()">دخول</button>
    </div>

    <div id="main-content">
        <div class="card">
            <p class="message-text">
                بصي بقى كدا.. عايزك تعرفي أول حاجة إني بحبك 
                وإني مقدرش أستغنى عنك أبدًا العُمر كله..
                وأهو كمّلنا انهارده سنة بحالها مع بعض! 
                بقالنا سنة بنتعارك ونهزر ونشتم ونبلك بعض وكل مرة بنرجع (أحلى علاقة توكسيك في الدنيا) 😂
                المهم ربنا يعلم أنا بحبك قد إيه وغلاوتك عندي قد إيه.. 
                أنا عمري مقعدت مع حد 6 شهور، قعدت معاكي أنتِ 12 شهر!
                وده معناه إنك مش زي أي حد، وإني بحبك بجد العُمر كله ♥️
                فـ ربنا يحفظك ليا ويديمك في حياتي دايماً يا رب 💗💗
            </p>
        </div>

        <audio id="bg-music" src="AUDIO-2026-05-22-01-14-54.mp3" loop></audio>

        <div class="gallery">
            <img src="e16c7ea9-b7d3-4c2b-a91e-bd8950c7cf5a.png" alt="صورة 1">
            <img src="a63a6328-d3a9-4885-ab64-1bb821ec5d5d.png" alt="صورة 2">
            <img src="5e1047cd-e23d-449e-bf03-324d3da89f3d.png" alt="صورة 3">
            <img src="227e1d02-9b11-4682-a39e-f9a41d1a95df.png" alt="صورة 4">
            <img src="b68147d4-3fef-437c-960c-151582f269f6.png" alt="صورة 5">
        </div>
    </div>

    <script>
        // دالة التحقق من الباسورد
        function checkPassword() {
            const input = document.getElementById('password-input').value;
            const correctPassword = "13/7/2009";

            if (input === correctPassword) {
                // إخفاء شاشة الباسورد وإظهار المحتوى
                document.getElementById('password-screen').style.opacity = '0';
                setTimeout(() => {
                    document.getElementById('password-screen').style.display = 'none';
                    document.getElementById('main-content').style.display = 'block';
                    
                    // تشغيل الأغنية تلقائياً عند الدخول
                    const music = document.getElementById('bg-music');
                    music.play().catch(error => {
                        console.log("التصفح يمنع التشغيل التلقائي بدون تفاعل أولاً");
                    });

                    // بدء إسقاط القلوب
                    setInterval(createHeart, 300);
                }, 500);
            } else {
                alert("الباسورد غلط.. ركزي وافتكري التاريخ كويس! 👀");
            }
        }

        // دالة صنع القلوب المتساقطة
        function createHeart() {
            const heart = document.createElement('div');
            heart.classList.add('heart');
            
            // اختيار شكل عشوائي للقلب
            const heartTypes = ['♥️', '💗', '🌸', '✨'];
            heart.innerText = heartTypes[Math.floor(Math.random() * heartTypes.length)];
            
            // مكان عشوائي للظهور بالعرض
            heart.style.left = Math.random() * 100 + "vw";
            // حجم عشوائي
            heart.style.fontSize = Math.random() * 10 + 12 + "px";
            // سرعة نزول عشوائية بين 3 لـ 6 ثواني
            heart.style.animationDuration = Math.random() * 3 + 3 + "s";
            
            document.body.appendChild(heart);
            
            // مسح القلب من الكود بعد ما يختفي
            setTimeout(() => {
                heart.remove();
            }, 6000);
        }
    </script>
</body>
</html>
